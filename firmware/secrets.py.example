# Copy this file to secrets.py and add your Wi-Fi credentials.
WIFI_SSID = "your_wifi_name"
WIFI_PASSWORD = "your_wifi_password"

# Optional display selector. Use "auto" unless detection fails on your board.
# Examples: "DISPLAY_INKY_FRAME_7", "DISPLAY_INKY_FRAME_5_7"
INKY_DISPLAY = "auto"
# Hardware target:
# - "auto"          -> detect from available modules (default)
# - "inkyframe"     -> force InkyFrame display/button behavior
# - "unicorn-pack"  -> Pimoroni Unicorn Pack (4-button Pico target)
HARDWARE_TARGET = "auto"
# 0 = highest quality/contrast updates (slower), larger values can be faster but ghost more.
DISPLAY_UPDATE_SPEED = 0

# Device profile:
# - "dual"  -> original local + remote dual clock experience
# - "japan" -> single full-screen Japan-focused clock/layout
# Note: Unicorn Pack has no e-ink screen; this profile still controls telemetry/mode labels.
DEVICE_PROFILE = "dual"

# Local/remote labels and fixed offsets used by the clock UI.
LOCAL_CITY_NAME = "VANCOUVER"
LOCAL_CITY_NAME_JP = "バンクーバー"
LOCAL_UTC_OFFSET = -7
LOCAL_TZ_LABEL = "PST"

REMOTE_CITY_NAME = "TOKYO"
REMOTE_CITY_NAME_JP = "東京"
REMOTE_UTC_OFFSET = 9
REMOTE_TZ_LABEL = "JST"

# Optional telemetry (multi-device dashboard support)
# Example API endpoint: https://api.sumilabu.com/api/device-stats
STATS_API_URL = ""
STATS_API_TOKEN = ""
# Keep your first two InkyFrame devices under "inkyframe".
# Use a separate key (for example "pico-unicorn") for the Unicorn Pack.
STATS_PROJECT_KEY = "inkyframe"
# Use a unique value per physical device.
STATS_DEVICE_ID = "inkyframe-office"
STATS_INTERVAL_SECONDS = 300
STATS_HTTP_TIMEOUT_S = 8

# Stability-first defaults (recommended for day-long uptime).
ENABLE_WATCHDOG = False
ENABLE_AUTO_RECOVER_RESET = False
WATCHDOG_TIMEOUT_MS = 8388

# Japan-only profile overrides (used when DEVICE_PROFILE="japan")
ACTIVE_CITY_NAME = "TOKYO"
ACTIVE_CITY_NAME_JP = "東京"
ACTIVE_UTC_OFFSET = 9
ACTIVE_TZ_LABEL = "JST"
