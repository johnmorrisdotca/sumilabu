# Neon Postgres pooled connection string (used by app queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Neon direct connection string (used by Prisma schema operations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Fallback ingestion token for all projects (unless overridden per project)
INGEST_API_TOKEN="replace-with-a-strong-token"

# Default product/project partition when payload omits project_key
DEFAULT_PROJECT_KEY="inkyframe"

# Optional per-project token overrides as JSON map.
# Use product keys such as inkyframe for SumiLabu Clock and onibako for Onibako.
# Do not commit real secrets.
# Example: {"inkyframe":"token-a","onibako":"token-b"}
PROJECT_TOKENS_JSON="{}"

# Optional stale threshold for UI status checks
STALE_AFTER_SECONDS="600"
